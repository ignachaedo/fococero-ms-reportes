{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "rootDir": "./src",
        "outDir": "./dist",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "strict": true,
        "sourceMap": true,
        "skipLibCheck": true,
        "typeRoots": ["./node_modules/@types", "./src/@types"],
        "types": ["jest", "node"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
